# SMTP Configuration
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=letsconnect@firstdoorhr.com
SMTP_PASS=your_smtp_password

# Email Settings
MAIL_FROM="First Door HR Solutions <letsconnect@firstdoorhr.com>"
BOOKING_RECEIVER_EMAIL=letsconnect@firstdoorhr.com

# Production Cloud Storage Configuration (Optional but required for Vercel/Netlify persistence)
# Use Supabase Storage:
SUPABASE_URL=your_supabase_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_BUCKET=brochures

# OR Use Cloudinary:
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
