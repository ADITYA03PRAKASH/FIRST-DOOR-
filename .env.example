# SMTP Configuration
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false # Set to true for 465, false for 587 or 25
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password

# Email Settings
MAIL_FROM="First Door HR Solutions <noreply@firstdoorhr.com>"
BOOKING_RECEIVER_EMAIL=yourcompany@example.com
